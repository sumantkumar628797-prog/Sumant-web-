SUPABASE_URL="https://xxxxxxxxxxxx.supabase.co"
SUPABASE_ANON_KEY="eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9..."

# Google Sheets / Make / Zapier Outgoing Webhook URL
GOOGLE_SHEETS_WEBHOOK_URL="https://hooks.zapier.com/hooks/catch/123456/yyy"

# ========================================================
